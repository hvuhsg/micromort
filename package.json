{
  "name": "micromort-project",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "npm run build && npx wrangler pages dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "db:migrate": "npx wrangler d1 migrations apply micromort-project --local",
    "db:migrate:remote": "npx wrangler d1 migrations apply micromort-project --remote"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^4.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "wrangler": "^3.0.0"
  },
  "type": "module"
}
